{
  "entities": {
    "Personnel": {
      "title": "Personnel",
      "description": "A staff member at the facility.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string", "enum": ["yemekhane", "yurt"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string", "description": "The user ID of the owner" }
      },
      "required": ["id", "name", "type", "createdAt", "uid"]
    },
    "Visitor": {
      "title": "Visitor",
      "description": "A visitor to the facility.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tc": { "type": "string" },
        "company": { "type": "string" },
        "plate": { "type": "string" },
        "material": { "type": "string" },
        "fromPlace": { "type": "string" },
        "entryTime": { "type": "string", "format": "date-time" },
        "exitTime": { "type": "string", "format": "date-time" },
        "uid": { "type": "string", "description": "The user ID of the owner" }
      },
      "required": ["id", "name", "entryTime", "uid"]
    },
    "City": {
      "title": "City",
      "description": "A city saved for weather tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "lat": { "type": "number" },
        "lon": { "type": "number" },
        "uid": { "type": "string", "description": "The user ID of the owner" }
      },
      "required": ["id", "name", "lat", "lon", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}/personnel/{personnelId}": {
      "schema": { "$ref": "#/entities/Personnel" },
      "description": "Personnel list scoped to the user"
    },
    "/users/{userId}/visitors/{visitorId}": {
      "schema": { "$ref": "#/entities/Visitor" },
      "description": "Visitor list scoped to the user"
    },
    "/users/{userId}/cities/{cityId}": {
      "schema": { "$ref": "#/entities/City" },
      "description": "Saved cities scoped to the user"
    }
  }
}
