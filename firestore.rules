rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, username, displayName, email, photoURL, createdAt
    //
    // Collection: chats
    // Fields: id, type, name, participants (array), lastMessage, lastMessageTime, createdAt
    //
    // Collection: chats/{chatId}/messages
    // Fields: id, chatId, senderId, senderName, text, timestamp
    //
    // Collection: personnel
    // Fields: id, name, type, phone, createdAt
    //
    // Collection: visitors
    // Fields: id, name, tc, company, plate, material, fromPlace, gate, entryTime, exitTime
    //
    // Collection: notes
    // Fields: id, title, content, color, createdAt
    //
    // Collection: shifts
    // Fields: id, date, type, notes
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "FKorkmaz703@gmail.com" && request.auth.token.email_verified == true));
    }

    function isChatParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email', 'createdAt']) &&
             data.uid is string && data.username is string && data.email is string;
    }

    function isValidPersonnel(data) {
      return data.keys().hasAll(['name', 'type', 'createdAt']) &&
             data.name is string && data.name.size() < 100 &&
             data.type in ['yemekhane', 'yurt'];
    }

    function isValidVisitor(data) {
      return data.keys().hasAll(['name', 'tc', 'company', 'entryTime']) &&
             data.name is string && data.tc is string && data.company is string;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt']) &&
             data.title is string && data.content is string;
    }

    function isValidShift(data) {
      return data.keys().hasAll(['date', 'type']) &&
             data.date is string && data.type in ['gunduz', 'gece', 'tatil'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
      }
    }

    match /personnel/{personnelId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidPersonnel(request.resource.data);
    }

    match /visitors/{visitorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidVisitor(request.resource.data);
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidNote(request.resource.data);
    }

    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidShift(request.resource.data);
    }
  }
}
